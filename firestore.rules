rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    // PROJETS : Simplifié au maximum pour éviter les "Permission Denied" lors des listes
    match /projects/{projectId} {
      allow read, write: if isAuthenticated();
      
      // Accès public par ID direct
      allow get: if resource.data.get('isPublic', false) == true;

      match /tasks/{taskId} {
        allow read, write: if isAuthenticated();
        // Accès public aux tâches si le projet est public
        allow get: if get(/databases/$(database)/documents/projects/$(projectId)).data.get('isPublic', false) == true;
      }
    }

    // UTILISATEURS
    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    // ACTIVITÉS, NOTIFICATIONS, COMMENTAIRES : Simplicité totale
    match /activities/{activityId} { allow read, write: if isAuthenticated(); }
    match /notifications/{notificationId} { allow read, write: if isAuthenticated(); }
    match /comments/{commentId} { allow read, write: if isAuthenticated(); }
    match /user_read_status/{statusId} { allow read, write: if isAuthenticated(); }
    match /reactions/{reactionId} { allow read, write: if isAuthenticated(); }

  }
}
