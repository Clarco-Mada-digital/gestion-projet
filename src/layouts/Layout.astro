---
import '../styles/global.css';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="fr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Application moderne de gestion de projets" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    
    <!-- PWA Meta Tags -->
    <meta name="theme-color" content="#3b82f6" />
    <meta name="description" content="Application de gestion de projets et tâches avec mode hors-ligne" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="GestionProjet" />
    
    <!-- PWA Manifest -->
    <link rel="manifest" href="./manifest.json" />
    
    <!-- Apple Touch Icons -->
    <link rel="apple-touch-icon" href="./icons/icon.svg" />
    
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style is:global>
      :root {
        --color-primary: 59, 130, 246;
        --color-secondary: 99, 102, 241;
      }
      
      body {
        @apply bg-gray-50 dark:bg-gray-900 text-gray-900 dark:text-gray-100 transition-colors duration-200;
      }
    </style>
  </head>
  <body class="min-h-screen font-sans antialiased bg-gradient-to-br from-gray-50 via-blue-50 to-purple-50 dark:from-gray-900 dark:via-blue-900/20 dark:to-purple-900/20">
    <slot />
    <script>
      // Enregistrement du Service Worker pour PWA
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('./sw.js')
          .then(registration => {
            console.log('✅ Service Worker enregistré pour PWA (Astro):', registration.scope);
          })
          .catch(error => {
            console.log('❌ Erreur enregistrement Service Worker (Astro):', error);
          });
      }
    </script>
    <script is:inline>
      // Le thème est maintenant géré par AppContext
      // L'initialisation se fait côté client via React
    </script>
  </body>
</html>